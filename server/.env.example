# PostgreSQL
POSTGRES_DB=rhythmlens
POSTGRES_USER=rhythmlens
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://rhythmlens:change_me@postgres:5432/rhythmlens

# Firebase
# Put the real service account JSON outside git and mount it into the backend container.
FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase-service-account.json

# Internal module-service URLs inside Docker Compose network
DIGITIZER_URL=http://digitizer-service:8001
COMPLETION_URL=http://completion-service:8002
ANALYSIS_URL=http://analysis-service:8003
SYNTHETIC_URL=http://synthetic-service:8004

# Runtime directories inside backend container
WORK_ROOT=/data/work
STORAGE_ROOT=/data/storage
